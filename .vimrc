set nocompatible

set backspace=indent,eol,start

set history=200

set ruler

set showcmd

set display=truncate

set incsearch

syntax on

filetype plugin indent on

set scrolloff=0

set showmode

set lazyredraw

set showmatch

set matchtime=2

set mouse=a

set ignorecase

set smartcase

set number

set relativenumber

set noswapfile

set nobackup

set undodir=~/.vim/undo-dir
set undofile

set scrolloff=8

set updatetime=50

set colorcolumn=80
